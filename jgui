    # Проверяем аргументы командной строки
    if len(sys.argv) > 1:
        arg = sys.argv[1].lower()
        
        # Обработка версии
        if arg in ["-v", "--v"]:
            print("jgui v0.3.0")
            sys.exit(0)
            
        # Обработка справки в терминале
        elif arg in ["-h", "--h", "-help", "--help"]:
            help_msg = (
                "jgui - Interactive TUI Editor for jgmenu\n\n"
                "Description:\n"
                "  This utility helps you easily manage your application menu.\n"
                "  It automatically creates and modifies the following files inside your home directory:\n"
                "    ~/.config/jgmenu/jgmenurc      - Main configuration file with automated bindings\n"
                "    ~/.config/jgmenu/vse_punkty.csv - Flat database containing your customized menu tree\n\n"
                "Usage:\n"
                "  jgui         Launch the interactive TUI interface\n"
                "  jgui -v      Show application version\n"
                "  jgui -h      Show this brief English help message"
            )
            print(help_msg)
            sys.exit(0)

    # Если аргументов нет, запускаем стандартный TUI-интерфейс
    try:
        curses.wrapper(main)
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)

